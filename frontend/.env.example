# ─── Firebase project config ───────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Enable Google as a sign-in provider under Authentication → Sign-in method
# Add http://localhost:5173 as an authorised domain
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── ZeroDev account abstraction ───────────────────────────────────────────────
# Get a free project ID at https://dashboard.zerodev.app
# Provisions a gasless ERC-4337 smart wallet for every signed-in player
VITE_ZERODEV_PROJECT_ID=
