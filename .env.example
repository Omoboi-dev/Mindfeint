# Copy to .env and fill in. NEVER commit .env (it holds a private key).

# Wallet used to pay for 0G Compute inference. Needs 0G testnet tokens.
PRIVATE_KEY=0xyour_private_key_here

# 0G Galileo testnet RPC
RPC_URL=https://evmrpc-testnet.0g.ai

# Optional: pin a specific 0G inference provider address.
# Leave blank to auto-pick the first discovered provider.
PROVIDER_ADDRESS=

# Address of the deployed MindfeintLog attestation contract (run: npm run deploy:attest).
# Leave blank to skip on-chain attestation (storage record still proves the round).
ATTEST_ADDRESS=

# How much 0G to deposit into the compute ledger if balance is empty.
# 0G requires a 3 0G MINIMUM to create the ledger (mostly refundable).
# Only used by the test script when --deposit is passed.
DEPOSIT_AMOUNT=3
